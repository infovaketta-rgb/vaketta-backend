# Dependencies
node_modules

# Build output / caches
dist
.next
coverage
*.tsbuildinfo

# Environment files — never ship secrets in the image or build context
.env
.env.*

# Git
.git
.github

# Logs
*.log
npm-debug.log*

# Tests — not needed at runtime; excluding shrinks the build context and keeps
# the builder stage from compiling them into dist/
src/**/*.test.ts
src/**/*.spec.ts
vitest.config.ts

# Orchestration files — not needed inside the image
docker-compose*.yml

# Editor files
.vscode
.idea

# OS files
.DS_Store
Thumbs.db

# Documentation — never copied into the image
*.md
